<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="backend.mapper.sqlite.SubFileMapper">

    <insert id="insert" parameterType="backend.model.entity.SubFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO SubFile (file_id, parent, name, relative_path, is_dir, is_sync, depth)
        VALUES (#{fileId}, #{parent}, #{name}, #{relativePath}, #{isDir}, #{isSync}, #{depth})
    </insert>

    <update id="update">
        UPDATE SubFile
        <set>
            <if test="parent != null">parent = #{parent},</if>
            <if test="name != null">name = #{name},</if>
            <if test="relativePath != null">relative_path = #{relativePath},</if>
            <if test="isDir != null">is_dir = #{isDir},</if>
            <if test="isSync != null">is_sync = #{isSync},</if>
            <if test="depth != null">depth = #{depth},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM SubFile WHERE id = #{id}
    </delete>

    <delete id="deleteByFileId">
        DELETE FROM SubFile WHERE file_id = #{fileId}
    </delete>

    <select id="selectByFileId" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile WHERE file_id = #{fileId}
    </select>

    <select id="selectByFileIdAndPath" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile WHERE file_id = #{fileId} AND relative_path = #{relativePath}
    </select>

    <select id="selectByFileIdAndParentIsNon" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile WHERE file_id = #{fileId} and parent is null
    </select>

    <select id="selectByPath" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile
        WHERE relative_path = #{path}
    </select>

    <select id="selectByParent" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile WHERE parent = #{parent}
    </select>

    <select id="selectByParentLimit" resultType="backend.model.entity.SubFile">
        SELECT * FROM SubFile WHERE file_id = #{fileId} limit 1
    </select>

    <update id="updateSyncByFileId">
        UPDATE SubFile
        SET is_sync = #{isSync}
        WHERE file_id = #{fileId}
    </update>

    <update id="markAsStale">
        UPDATE SubFile SET is_sync = false WHERE id = #{id}
    </update>

</mapper>