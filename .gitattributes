# Auto-detect text files and normalise line endings to LF in the repo
* text=auto

# Force LF for shell scripts (critical for CI on Linux)
*.sh text eol=lf
mvnw text eol=lf

# Force LF for other text-based config that might be executed
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.cjs text eol=lf

# Force CRLF for Windows batch files
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files — don't touch
*.png binary
*.ico binary
*.icns binary
*.jar binary
*.db binary
