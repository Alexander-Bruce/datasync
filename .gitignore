# ============================================================
# OS files
# ============================================================
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
# Editors and IDEs
# ============================================================
.idea/
.vscode/
.settings/
.classpath
.project
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# ============================================================
# Logs and runtime output
# ============================================================
*.log
*.log.*
spring.log
RUNNING.txt
logs/
log/
**/logs/
**/log/

# ============================================================
# Temporary files
# ============================================================
*.tmp
*.temp
*.bak
*.old
*.orig
*.part
*.pid
*.pid.lock
*.seed
tmp/
temp/
.cache/

# ============================================================
# Secrets, certificates, and RSA keys
# ============================================================
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
# Keep example files in version control
!*.example.pem
!*.example.key

# ============================================================
# Environment and local configuration
# (never commit real credentials — use *.example files)
# ============================================================
.env
.env.*
!.env.example
!.env.*.example
*.local
*.local.*
**/application-local.yml
**/application-local.yaml
**/application-prod.yml
**/application-prod.yaml

# ============================================================
# Runtime data generated by the server
# ============================================================
# Group metadata stored by GroupServiceImpl at runtime
groups.json
**/groups.json

# ============================================================
# Local databases
# ============================================================
*.db
*.db-*
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal

# ============================================================
# Java / Maven
# ============================================================
**/target/
*.class
*.war
*.ear
hs_err_pid*
replay_pid*
dependency-reduced-pom.xml
.mvn/timing.properties
# Keep the Maven wrapper jar so the project builds without a local Maven install
!**/.mvn/wrapper/maven-wrapper.jar

# ============================================================
# Node.js / Electron / Vue / Vite
# ============================================================
node_modules/
**/node_modules/
dist/
**/dist/
dist-electron/
**/dist-electron/
release/
**/release/
out/
**/out/
*.tsbuildinfo
.eslintcache
**/.eslintcache
.vite/
**/.vite/
coverage/
**/coverage/
.nyc_output/
.node_repl_history
*.heapsnapshot

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# Electron build artifacts
# ============================================================
*.dmg
*.exe
*.AppImage
*.deb
*.rpm
*.msi
*.snap
*.blockmap
latest*.yml
builder-debug.yml
builder-effective-config.yaml

# ============================================================
# Office temporary files
# ============================================================
~$*
